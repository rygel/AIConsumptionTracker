<Window x:Class="AIUsageTracker.UI.Slim.CardDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card Designer" Height="700" Width="500"
        MinWidth="400" MinHeight="500"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource Background}"
        Foreground="{DynamicResource PrimaryText}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ComboBoxItemHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}" Padding="12,8"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="X" Click="CloseBtn_Click"
                        Background="Transparent" Foreground="{DynamicResource SecondaryText}"
                        BorderThickness="0" Padding="8,2" FontWeight="Bold" Cursor="Hand"/>
                <TextBlock Text="Card Designer" FontWeight="Bold" FontSize="13"
                           Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Slot Configuration -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}" Padding="12,10"
                Margin="8,8,8,0" BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="CARD SLOTS" FontWeight="Bold" FontSize="11"
                           Foreground="{DynamicResource AccentColor}" Margin="0,0,0,10"/>

                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Primary Badge" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" FontSize="11"/>
                    <ComboBox x:Name="PrimaryBadgeSlot" Grid.Column="1" Height="24"
                              Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource ControlBorder}" SelectionChanged="SlotConfig_Changed"/>
                </Grid>

                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Secondary Badge" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" FontSize="11"/>
                    <ComboBox x:Name="SecondaryBadgeSlot" Grid.Column="1" Height="24"
                              Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource ControlBorder}" SelectionChanged="SlotConfig_Changed"/>
                </Grid>

                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Status Line" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" FontSize="11"/>
                    <ComboBox x:Name="StatusLineSlot" Grid.Column="1" Height="24"
                              Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource ControlBorder}" SelectionChanged="SlotConfig_Changed"/>
                </Grid>

                <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Reset Info" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" FontSize="11"/>
                    <ComboBox x:Name="ResetInfoSlot" Grid.Column="1" Height="24"
                              Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource ControlBorder}" SelectionChanged="SlotConfig_Changed"/>
                </Grid>

                <!-- Presets -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Presets:" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="11"/>
                    <Button Content="Compact" Click="PresetCompact_Click" Padding="8,3" Margin="0,0,4,0"
                            Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource PrimaryText}"
                            BorderThickness="0" FontSize="10" Cursor="Hand"/>
                    <Button Content="Detailed" Click="PresetDetailed_Click" Padding="8,3" Margin="0,0,4,0"
                            Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource PrimaryText}"
                            BorderThickness="0" FontSize="10" Cursor="Hand"/>
                    <Button Content="Pace Focus" Click="PresetPace_Click" Padding="8,3"
                            Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource PrimaryText}"
                            BorderThickness="0" FontSize="10" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Live Preview -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="8">
            <StackPanel x:Name="PreviewStack"/>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource FooterBackground}" Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Apply to Main Window" Click="ApplyBtn_Click"
                        Padding="12,5" Background="{DynamicResource AccentColor}"
                        Foreground="{DynamicResource AccentForeground}"
                        BorderThickness="0" Cursor="Hand" FontSize="11"/>
                <TextBlock Text="Live preview with your real provider data"
                           Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" FontSize="10"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
